# --- Teacher LLM (OpenAI-compatible) ---
# Works with OpenAI directly, or any OpenAI-compatible endpoint (including the
# lower-cost teacher you'll be provided). The label-first design keeps gold-label
# quality high even with a weaker teacher, because the teacher never has to
# *detect* biases -- only embed them and explain them given the answer.

OPENAI_API_KEY=sk-your-key-here

# Optional: point at a different OpenAI-compatible teacher.
# Leave blank to use OpenAI's default endpoint.
OPENAI_BASE_URL=

# Model used to generate strategies and gold audits.
# Swap this for whatever teacher you're given (e.g. a local/hosted model name).
TEACHER_MODEL=gpt-4o-mini
